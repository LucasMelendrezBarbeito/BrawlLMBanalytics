# Variables de entorno requeridas por la app.
# Copia estos nombres a las variables de entorno de tu sistema/sesion.
# NUNCA commitees los valores reales (este archivo solo documenta los nombres).

# Secreto para firmar los JWT (HS256). Genera uno propio, minimo 32 bytes.
# Ejemplo para generarlo:  openssl rand -base64 48
JWT_SECRET=pon-aqui-un-secreto-largo-y-aleatorio

# Token de la API oficial de Supercell (https://developer.brawlstars.com/),
# generado e IP-registrado. Debe coincidir con tu IP publica actual.
SUPERCELL_TOKEN=pon-aqui-tu-token-de-supercell

# Credenciales de MySQL. Si no las defines, se usan los valores por defecto
# (usuario 'root' y contrasena vacia), que es la config de XAMPP por defecto.
DB_USERNAME=root
DB_PASSWORD=
